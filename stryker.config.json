{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker4s/master/core/src/main/resources/stryker-core-schema.json",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.d.ts"
  ],
  "testRunner": "vitest",
  "reporters": [
    "html",
    "clear-text",
    "progress"
  ],
  "coverageAnalysis": "perTest"
}